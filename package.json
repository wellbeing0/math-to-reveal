{
  "name": "math-to-reveal",
  "version": "0.1.0",
  "description": "Browser-first elementary math practice with video reveal rewards.",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.19 <25",
    "npm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wellbeing0/math-to-reveal.git"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:host": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "spec:validate": "openspec validate --specs",
    "check": "npm run check:public-clean && npm test && npm run build && npm run spec:validate",
    "check:public-clean": "bash scripts/check-public-clean.sh ."
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@fission-ai/openspec": "^1.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  }
}
